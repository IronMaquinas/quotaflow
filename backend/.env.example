# ─── COPIE ESTE ARQUIVO PARA .env E PREENCHA ───
# NÃO commite o arquivo .env no GitHub!

# Porta do servidor (Railway define automaticamente)
PORT=3001

# Segredo para geração de tokens JWT (coloque qualquer string longa e aleatória)
JWT_SECRET=coloque_uma_string_muito_longa_e_aleatoria_aqui_ex_xK9mP2qR7vL

# Chave da API do Resend (obtenha em resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# E-mail remetente (deve ser verificado no Resend)
EMAIL_FROM=cotacoes@suaempresa.com.br

# URL do frontend (para links nos e-mails)
# Em desenvolvimento: http://localhost:5173
# Em produção: https://seuapp.railway.app
FRONTEND_URL=http://localhost:5173

# Nome da empresa (aparece nos e-mails)
EMPRESA_NOME=Minha Empresa Ltda
